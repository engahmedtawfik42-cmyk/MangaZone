g-0HdmLGGsC\",\"g-1sGW39CE8\",\"g-DHgM6S2lz\",\"g-B7pw2N4Jo\",\"g-dZbTnE4Cw\",\"g-ms1OIHWwC\",\"g-carHK0JOD\",\"g-pzuSUOitu\",\"g-67693ea14b888191811470eafb2b2c25\",\"g-7Mv2u5ScD\",\"g-IUVMlbwdS\",\"g-BvpyeGAwb\",\"g-gmxjuCib5\",\"g-RfzqVcIAo\",\"g-WcEr33kYO\",\"g-vI5VhBAvx\",\"g-D6ty4KgPD\",\"g-3vS7xOWFy\",\"g-VyTNR70hB\",\"g-AwgeVMTI2\",\"g-7iDZfdbeO\",\"g-JMWdcVMps\",\"g-89Xp4s6hH\",\"g-SrzWBUIQ4\"]},\"is_device_based\":true,\"passed\":false},\"2889497622\":{\"name\":\"2889497622\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true,\"requested_model_slugs\":[\"gpt-5-5-pro\",\"gpt-5-5-thinking\"]},\"is_device_based\":false,\"passed\":false},\"734083401\":{\"name\":\"734083401\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"kind\":\"username\",\"enabled\":true,\"loginStrategy\":\"existing_user\",\"tempDisabled\":false,\"name\":\"email\"},\"is_device_based\":false,\"passed\":false},\"463092697\":{\"name\":\"463092697\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"4113286138\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"251005210\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"733205176\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"user_prompt_key\":\"good_option\"},\"is_device_based\":false,\"passed\":false},\"3487666121\":{\"name\":\"3487666121\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[{\"gate\":\"1187522884\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"859770335\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"stableID\",\"value\":{\"should_auto_open_pricing_modal_logged_in_with_spinner\":false,\"show_new_pricing_page_general_ui\":false,\"variant\":0,\"show_new_pricing_card_ui\":false},\"is_device_based\":true,\"is_in_layer\":true,\"explicit_parameters\":[\"variant\",\"show_new_pricing_card_ui\",\"show_new_pricing_page_general_ui\"],\"group_name\":\"Control\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"365985288\":{\"name\":\"365985288\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"maverick\":[],\"trailblazer\":[],\"stratos\":[],\"pioneer\":[],\"seeker\":