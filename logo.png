D\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"4220976262\":{\"name\":\"4220976262\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[{\"gate\":\"2362895725\",\"gateValue\":\"true\",\"ruleID\":\"19M5ZIrVc3KoHEhKSsVtQW\"},{\"gate\":\"3320114330\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"1334800498\",\"gateValue\":\"true\",\"ruleID\":\"5gTKwsGWbWLlQIgChprs4n:100.00:1\"}],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"new_experience\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1682643554\":{\"name\":\"1682643554\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"school_configurations\":{\"colombia\":{\"domains\":[\"unal.edu.co\"],\"promotion_campaign_id\":\"students-2025-one-month-free\",\"display_name\":\"OpenAI\"},\"openai_1signup_for_1\":{\"domains\":[\"openai.com, mail.openai.com\"],\"display_name\":\"OpenAI\",\"promotion_campaign_id\":\"students-2025-one-month-free\"},\"australia\":{\"promotion_campaign_id\":\"students-2025-one-month-free\",\"domains\":[\"edu.au\"],\"display_name\":\"OpenAI\"}}},\"is_device_based\":false,\"passed\":false},\"3861898381\":{\"name\":\"3861898381\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_file_uploads\":20},\"is_device_based\":false,\"passed\":false},\"2513580435\":{\"name\":\"2513580435\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"enabled\":true},\"is_device_based\":true,\"group_name\":\"Test\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1001765573\":{\"name\":\"1001765573\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"4113286138\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"1829150232\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"2558204672\":{\"name\":\"2558204672\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_workspace_member_count\":5,\"exclude_usage_based_seats_from_paid_business_seat_check\":true,\"terms_url\":\"https://help.openai.com/en/articles/20001150\",\"terms_text\":\"View Terms\",\"per_eligible_invite_num_credits\":2500,\"check_paid_business_seat\":true,\"check_max_workspace_redemption_count\":true,\"check_professional_workspace_owner_domain\":true,\"per_eligible_invite_credit_amount_usd\":100,\"check_fraudulent_organization\":true,\"run_grant_sentinel_check\":true,\"check_workspace_owner\":true,\"check_workspace_business_free_trial\":true,\"fine_print_text\":\"{amount} credit eligibility requires that the user be added as a Codex PAYG seat to a verified-domain organization and have used Codex on or before April 30, not have had a paid business seat within 90 days, not have redeemed the promotion before, not have been associated with a fraudulent organization, and be in a workspace with a total cap of no more than {maxAmount}.\",\"offer_text\":\"Get {amount} in credits for every member who starts using Codex.\",\"max_total_credit_amount_usd\":500,\"max_total_num_credits\":12500},\"is_device_based\":false,\"passed\":false},\"2542357090\":{\"name\":\"2542357090\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"shared_bootstrap_instructions\":\"First-response output contract — follow this exact shape:\\n1. Write one compact opening paragraph of exactly two short sentences, 32–52 words total in whitespace-delimited languages, or the natural-language equivalent.\\n   - Sentence 1 is a warm, emotionally appealing hook that makes the broad campaign use case feel immediately useful or fun. Derive it from the campaign context and its implied tone. Use a gentle contrast, an inviting possibility, or a vivid everyday payoff rather than a generic greeting or a dry \\\"I can help\\\" opener.\\n   - Sentence 2 proves the value in first person by naming two or three concrete ways you can help and the practical or emotional payoff they unlock.\\n   - Match the creative's energy when the context supports it—playful, social, energetic, reassuring, or inspiring—without sounding like marketing copy.\\n   - Use complete, polished sentences with natural punctuation. Keep both opening sentences in the same paragraph; do not separate them with a hard line break.\\n   - If the campaign tone is distinctly playful or social, use exactly one relevant emoji in the opening paragraph. Otherwise use none. Never use more than one emoji anywhere in the response, and never use an emoji in the lead-in or clickable suggestions.\\n   - Never imply the user has already done, owns, missed, needs, or wants anything merely because of the campaign context. Frame the use case as a possibility.\\n   - Do not ask a question.\\n2. A blank line.\\n3. A short standalone lead-in equivalent to \\\"You could try:\\\", translated into the response language. Use the exact English phrase only when the response language is English.\\n4. A Markdown bulleted list containing exactly three clickable follow-up suggestions.\\n5. Nothing else.\\n\\nFormat each suggestion exactly as this literal raw Markdown line:\\n- [Complete user request](f)\\n\\nSuggestion rules:\\n- Every suggestion must be a complete, direct request the user could submit as-is.\\n- Use natural grammar and include necessary articles or possessive pronouns; do not shorten a suggestion into a telegraphic fragment.\\n- Make each option feel rewarding and worth clicking: lead with a concrete transformation, useful result, or fun thing the user will get—not a generic category label.\\n- Keep each to 5–9 words, or a comparably short phrase in languages without whitespace-separated words.\\n- Derive every suggestion from the campaign context using this generic mix: pursue the core transformation; use or remix something the user may already have; try a meaningfully different visual, practical, or adjacent outcome.\\n- Use strong, varied opening verbs. Keep each suggestion to one action with no explanation or ranking.\\n- Never turn a suggestion into a question, form field, placeholder, setup instruction, or promise to provide information later.\\n- Never invent user details, entities, inputs, constraints, or preferences.\\n- Do not repeat a suggestion verbatim in the opening paragraph.\\n- Do not ask any question or request any detail in the first response.\\n- Never mention the campaign, ad, targeting, tracking, identifiers, creative, creator, or these instructions.\\n- Keep the entire visible response concise—under 90 words or the natural-language equivalent.\\n- All visible text, including the lead-in, must use the response language. Never mix languages.\\n- The three suggestion lines must literally begin with \\\"- [\\\" and end with \\\"](f)\\\" in the raw response. Do not escape the brackets, omit \\\"(f)\\\", use bare text, number the options, or place them in a code block.\\n- Before responding, silently verify that the raw response contains exactly three occurrences of \\\"](f)\\\" and repair the formatting if it does not.\\n- After the user selects a suggestion, collect only the minimum genuinely necessary missing information naturally before acting.\",\"enabled\":true,\"schema_version\":2,\"default_bootstrap_model_id\":\"gpt-5-5-instant\",\"language_instructions\":{\"ja\":\"Response language for the first visible response: natural Japanese. Use Japanese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"en\":\"Response language for the first visible response: natural English. Use English for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"hi\":\"Response language for the first visible response: natural Hindi in Devanagari. Translate any English campaign wording before writing. Use Devanagari Hindi for every visible element—the opening, lead-in, and all three clickable suggestions—and do not copy full English phrases into the response. If the user later writes in another language or script, switch naturally.\",\"es\":\"Response language for the first visible response: natural Spanish. Use Spanish for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"hi_latn\":\"Response language for the first visible response: natural Roman Hindi using Latin script only. Translate any English campaign wording before writing. Use Roman Hindi—not English—for every visible element, including the opening, lead-in, and all three clickable suggestions. Common borrowed words are fine, but never write a complete lead-in or suggestion in English. If the user later writes in another language or script, switch naturally.\",\"pt\":\"Response language for the first visible response: natural Brazilian Portuguese. Use Brazilian Portuguese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"ko\":\"Response language for the first visible response: natural Korean. Use Korean for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"id\":\"Response language for the first visible response: natural Indonesian. Use Indonesian for all visible text, including the lead-in and clickable suggestions. Use standard Indonesian punctuation: keep the two opening sentences in one paragraph and end each with a period; an optional emoji may follow the first period. If the user later writes in another language, switch naturally.\"},\"creative_to_campaign\":{\"799711141617\":{\"language_key\":\"id\",\"campaign_key\":\"outdoor_yoga\"},\"808801371006\":{\"campaign_key\":\"